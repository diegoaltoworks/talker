# ~~~ Required ~~~ 
# (LLMs integration)

# OpenAI/Anthropic API key
OPENAI_CHATGPT_KEY=sk-proj-...

# ~~~ Chatbot ~~~ 
# (Knowledge-base chatbot API — standalone mode only)

# Chatbot API URL (e.g., chatter's /api/public/chat endpoint)
CHATBOT_URL=https://bot.example.com/api/public/chat
# API key for the chatbot
CHATBOT_API_KEY=your-chatbot-api-key

# ~~~ Twilio ~~~ 
# (for outbound SMS)

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+441234567890

# ~~~ Turso ~~~ 
# (Database integration — plugin mode only)

TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ~~~ Optional ~~~ 

# Server port (default: 3000)
PORT=3000
# Environment
NODE_ENV=development
# Enable debug logging in tests
DEBUG=true
