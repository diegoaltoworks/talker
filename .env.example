# ~~~ Required ~~~ 
# (LLMs integration)

# OpenAI/Anthropic API key — used for the pre/post-processing pipeline
OPENAI_CHATGPT_KEY=sk-proj-...

# ~~~ Chatbot ~~~ 
# (Remote chatbot API — standalone mode only)
# In plugin mode these are not needed; talker calls chatter's RAG directly.

# Chatbot API URL (e.g., chatter's /api/public/chat endpoint)
CHATBOT_URL=https://bot.example.com/api/public/chat
# API key for the chatbot (sent as x-api-key header)
CHATBOT_API_KEY=your-chatbot-api-key

# ~~~ Twilio ~~~ 
# (for voice calls and outbound SMS)

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+441234567890

# ~~~ Turso ~~~ 
# (Database integration — session persistence)
# In plugin mode, falls back to chatter's database config (same DB, different tables).

TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ~~~ Optional ~~~ 

# Phone number to transfer calls to when human handoff is requested
TRANSFER_NUMBER=+441234567890
# Server port (default: 3000)
PORT=3000
# Environment
NODE_ENV=development
# Enable debug logging in tests
DEBUG=true
